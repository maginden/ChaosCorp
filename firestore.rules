rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidPoll(data) {
      return data.question is string && data.question.size() < 500 &&
             data.options is list && data.options.size() <= 10 &&
             data.votes is map &&
             data.active is bool;
    }

    function isValidQuizResult(data) {
      return data.studentName is string && data.studentName.size() > 0 && data.studentName.size() < 100 &&
             data.score is int && data.score >= 0 &&
             data.timestamp is string;
    }

    match /polls/{pollId} {
      allow read: if true;
      allow update: if true; // Allow students to vote (simplified for demo, ideally use atomic increments)
      allow create, delete: if true; // In a real app, only admin
    }

    match /quizResults/{resultId} {
      allow read: if true;
      allow create: if isValidQuizResult(request.resource.data);
    }

    match /session/state {
      allow read: if true;
      allow write: if true;
    }
  }
}
